<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf">

    <Style x:Key="MaterialDesignToggleButtonWithIcon" BasedOn="{StaticResource MaterialDesignFloatingActionButton}" TargetType="{x:Type ToggleButton}" />

    <Style x:Key="MaterialDesignRaisedCancelButton" BasedOn="{StaticResource MaterialDesignRaisedButton}" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="#FFAB3838" />
        <Setter Property="BorderBrush" Value="#FFA71919" />
    </Style>

    <!--
        ============================================================
        FFXIVPlugins fork: CommsLink color palette
        Source of truth: H:/Development/CommsLink2/services/web/styles/colorVariables.scss
        ============================================================
    -->

    <!-- CommsLink raw colors -->
    <Color x:Key="CommsLinkBackground">#FF0D1117</Color>
    <Color x:Key="CommsLinkPaper">#FF161B22</Color>
    <Color x:Key="CommsLinkSurface">#FF1C2128</Color>
    <Color x:Key="CommsLinkPrimary">#FF569CD6</Color>
    <Color x:Key="CommsLinkPrimaryDark">#FF4080BF</Color>
    <Color x:Key="CommsLinkPrimaryLight">#FF9CDCFE</Color>
    <Color x:Key="CommsLinkTextPrimary">#FFCCCCCC</Color>
    <Color x:Key="CommsLinkTextSecondary">#FF858585</Color>
    <Color x:Key="CommsLinkTextMuted">#FF5A5A5A</Color>
    <Color x:Key="CommsLinkSuccess">#FF6A9955</Color>
    <Color x:Key="CommsLinkError">#FFF44747</Color>
    <Color x:Key="CommsLinkWarning">#FFCCA700</Color>

    <SolidColorBrush x:Key="CommsLinkBackgroundBrush" Color="{StaticResource CommsLinkBackground}" />
    <SolidColorBrush x:Key="CommsLinkPaperBrush" Color="{StaticResource CommsLinkPaper}" />
    <SolidColorBrush x:Key="CommsLinkSurfaceBrush" Color="{StaticResource CommsLinkSurface}" />
    <SolidColorBrush x:Key="CommsLinkPrimaryBrush" Color="{StaticResource CommsLinkPrimary}" />
    <SolidColorBrush x:Key="CommsLinkPrimaryDarkBrush" Color="{StaticResource CommsLinkPrimaryDark}" />
    <SolidColorBrush x:Key="CommsLinkPrimaryLightBrush" Color="{StaticResource CommsLinkPrimaryLight}" />
    <SolidColorBrush x:Key="CommsLinkTextPrimaryBrush" Color="{StaticResource CommsLinkTextPrimary}" />
    <SolidColorBrush x:Key="CommsLinkTextSecondaryBrush" Color="{StaticResource CommsLinkTextSecondary}" />

    <!--
        Override the MaterialDesign brush keys that the launcher's XAML
        binds to via {DynamicResource MaterialDesign...}.
        Both the legacy keys and the new MD3 keys are overridden so we
        catch every binding regardless of which one a control uses.
    -->

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="MaterialDesignPaper" Color="{StaticResource CommsLinkPaper}" />
    <SolidColorBrush x:Key="MaterialDesignBackground" Color="{StaticResource CommsLinkBackground}" />
    <SolidColorBrush x:Key="MaterialDesignCardBackground" Color="{StaticResource CommsLinkSurface}" />
    <SolidColorBrush x:Key="MaterialDesignToolBarBackground" Color="{StaticResource CommsLinkPaper}" />
    <SolidColorBrush x:Key="MaterialDesignChipBackground" Color="{StaticResource CommsLinkSurface}" />
    <SolidColorBrush x:Key="MaterialDesignDivider" Color="#FF30363D" />

    <SolidColorBrush x:Key="MaterialDesign.Brush.Background" Color="{StaticResource CommsLinkBackground}" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.Surface" Color="{StaticResource CommsLinkSurface}" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.Card.Background" Color="{StaticResource CommsLinkSurface}" />

    <!-- Foreground / text -->
    <SolidColorBrush x:Key="MaterialDesignBody" Color="{StaticResource CommsLinkTextPrimary}" />
    <SolidColorBrush x:Key="MaterialDesignBodyLight" Color="{StaticResource CommsLinkTextSecondary}" />
    <SolidColorBrush x:Key="MaterialDesignColumnHeader" Color="{StaticResource CommsLinkTextSecondary}" />
    <SolidColorBrush x:Key="MaterialDesignCheckBoxOff" Color="{StaticResource CommsLinkTextSecondary}" />
    <SolidColorBrush x:Key="MaterialDesignCheckBoxDisabled" Color="{StaticResource CommsLinkTextMuted}" />

    <SolidColorBrush x:Key="MaterialDesign.Brush.Foreground" Color="{StaticResource CommsLinkTextPrimary}" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.Body" Color="{StaticResource CommsLinkTextPrimary}" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.Body.Light" Color="{StaticResource CommsLinkTextSecondary}" />

    <!-- Primary brand color -->
    <SolidColorBrush x:Key="PrimaryHueLightBrush" Color="{StaticResource CommsLinkPrimaryLight}" />
    <SolidColorBrush x:Key="PrimaryHueLightForegroundBrush" Color="#FF000000" />
    <SolidColorBrush x:Key="PrimaryHueMidBrush" Color="{StaticResource CommsLinkPrimary}" />
    <SolidColorBrush x:Key="PrimaryHueMidForegroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="PrimaryHueDarkBrush" Color="{StaticResource CommsLinkPrimaryDark}" />
    <SolidColorBrush x:Key="PrimaryHueDarkForegroundBrush" Color="#FFFFFFFF" />

    <SolidColorBrush x:Key="MaterialDesign.Brush.Primary" Color="{StaticResource CommsLinkPrimary}" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.Primary.Light" Color="{StaticResource CommsLinkPrimaryLight}" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.Primary.Dark" Color="{StaticResource CommsLinkPrimaryDark}" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.Primary.Foreground" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.Primary.Light.Foreground" Color="#FF000000" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.Primary.Dark.Foreground" Color="#FFFFFFFF" />

    <!-- Secondary defaults to primary so accent buttons are still on-brand -->
    <SolidColorBrush x:Key="SecondaryHueLightBrush" Color="{StaticResource CommsLinkPrimaryLight}" />
    <SolidColorBrush x:Key="SecondaryHueMidBrush" Color="{StaticResource CommsLinkPrimary}" />
    <SolidColorBrush x:Key="SecondaryHueDarkBrush" Color="{StaticResource CommsLinkPrimaryDark}" />
    <SolidColorBrush x:Key="SecondaryHueLightForegroundBrush" Color="#FF000000" />
    <SolidColorBrush x:Key="SecondaryHueMidForegroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="SecondaryHueDarkForegroundBrush" Color="#FFFFFFFF" />

    <SolidColorBrush x:Key="MaterialDesign.Brush.Secondary" Color="{StaticResource CommsLinkPrimary}" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.Secondary.Light" Color="{StaticResource CommsLinkPrimaryLight}" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.Secondary.Dark" Color="{StaticResource CommsLinkPrimaryDark}" />

    <!-- Validation / status -->
    <SolidColorBrush x:Key="ValidationErrorBrush" Color="{StaticResource CommsLinkError}" />
    <SolidColorBrush x:Key="MaterialDesign.Brush.ValidationError" Color="{StaticResource CommsLinkError}" />

</ResourceDictionary>
